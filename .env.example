# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID чата (отрицательное число для группы, например -1001234567890)
CHAT_ID=your_chat_id_here

# API ключ ClaudeHub
CLAUDEHUB_API_KEY=sk-hub-xxxxxxxx

# Модель Anthropic/Claude
# claude-haiku-4.5
# claude-sonnet-4.6
# claude-opus-4.5
# claude-opus-4.6
# claude-opus-4.7
# gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4.6

# Размер Whisper модели: tiny, base, small, medium
# small — хороший баланс скорости и качества для русского языка
WHISPER_MODEL=small

# Часовой пояс для планировщика (7 утра по этому времени)
SCHEDULER_TZ=Europe/Moscow
