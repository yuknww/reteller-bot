# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID чата (отрицательное число для группы, например -1001234567890)
CHAT_ID=your_chat_id_here

# API ключ OpenRouter (openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Модель OpenRouter (бесплатные варианты):
# meta-llama/llama-3.3-70b-instruct:free
# google/gemini-2.0-flash-exp:free
# deepseek/deepseek-chat-v3-0324:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Размер Whisper модели: tiny, base, small, medium
# small — хороший баланс скорости и качества для русского языка
WHISPER_MODEL=small

# Часовой пояс для планировщика (7 утра по этому времени)
SCHEDULER_TZ=Europe/Moscow
